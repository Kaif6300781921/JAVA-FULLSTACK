import java.util.Scanner;

class  PRIME
{
	public static void main(String[] args) 
	{
Scanner scn = new Scanner(System.in);

		System.out.println("enter a num of prim nums");
		int n=scn.nextInt();
		int count=0;
		for(int i=1; true; i++){
			if (i<=1) continue;
			Boolean flag=true;
			for (int j=2;j<=i/2;j++){
				if (i%j==0){
					flag=false;
					break;
				}
			}
			if (flag){
				System.out.println(i);
				if((count==n) break;
			}
		}
	}
			
